{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-msvc-debug",
            "displayName": "Windows MSVC Debug",
            "generator": "Visual Studio 17 2022",
            "toolchainFile": "${sourceDir}/CMake/Toolchains/Windows64.cmake",
            "toolset": {
                "value": "v143",
                "strategy": "set"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "binaryDir": "${sourceDir}/Build/windows-msvc-debug",
            "cacheVariables": {
                "VE_BUILD_PLAYER": "ON",
                "VE_BUILD_EDITOR": "ON",
                "VE_BUILD_TESTS": "OFF",
                "VE_BUILD_TOOLS": "ON",
                "VE_BUILD_MAC_PLAYER": "ON",
                "VE_ENABLE_D3D11": "ON",
                "VE_ENABLE_D3D12": "ON",
                "VE_ENABLE_METAL": "OFF"
            }
        },
        {
            "name": "windows-msvc-release",
            "displayName": "Windows MSVC Release",
            "inherits": "windows-msvc-debug",
            "binaryDir": "${sourceDir}/Build/windows-msvc-release"
        },
        {
            "name": "windows-msvc-tests",
            "displayName": "Windows MSVC Tests",
            "inherits": "windows-msvc-debug",
            "binaryDir": "${sourceDir}/Build/windows-msvc-tests",
            "cacheVariables": {
                "VE_BUILD_PLAYER": "OFF",
                "VE_BUILD_EDITOR": "OFF",
                "VE_BUILD_TESTS": "ON",
                "VE_BUILD_TOOLS": "OFF"
            }
        },
        {
            "name": "mac-debug",
            "displayName": "macOS Debug",
            "generator": "Xcode",
            "toolchainFile": "${sourceDir}/CMake/Toolchains/Mac.cmake",
            "binaryDir": "${sourceDir}/Build/mac-debug",
            "cacheVariables": {
                "VE_MAC_PLATFORM": "MACOS",
                "VE_BUILD_PLAYER": "ON",
                "VE_BUILD_EDITOR": "ON",
                "VE_BUILD_TESTS": "OFF",
                "VE_BUILD_TOOLS": "ON",
                "VE_BUILD_MAC_PLAYER": "ON",
                "VE_ENABLE_D3D11": "OFF",
                "VE_ENABLE_D3D12": "OFF",
                "VE_ENABLE_METAL": "ON"
            }
        },
        {
            "name": "mac-release",
            "displayName": "macOS Release",
            "inherits": "mac-debug",
            "binaryDir": "${sourceDir}/Build/mac-release"
        },
        {
            "name": "mac-test",
            "displayName": "macOS Test",
            "inherits": "mac-debug",
            "binaryDir": "${sourceDir}/Build/mac-test",
            "cacheVariables": {
                "VE_BUILD_PLAYER": "OFF",
                "VE_BUILD_EDITOR": "OFF",
                "VE_BUILD_TESTS": "ON",
                "VE_BUILD_TOOLS": "OFF"
            }
        },
        {
            "name": "ios-device-debug",
            "displayName": "iOS Device Debug",
            "generator": "Xcode",
            "toolchainFile": "${sourceDir}/CMake/Toolchains/IOS.cmake",
            "binaryDir": "${sourceDir}/Build/ios-device-debug",
            "cacheVariables": {
                "VE_IOS_SDK": "iphoneos",
                "VE_IOS_ARCHITECTURES": "arm64",
                "VE_BUILD_PLAYER": "ON",
                "VE_BUILD_EDITOR": "OFF",
                "VE_BUILD_TESTS": "OFF",
                "VE_BUILD_TOOLS": "OFF",
                "VE_BUILD_MAC_PLAYER": "OFF",
                "VE_BUILD_IOS_PLAYER": "ON",
                "VE_ENABLE_D3D11": "OFF",
                "VE_ENABLE_D3D12": "OFF",
                "VE_ENABLE_METAL": "ON"
            }
        },
        {
            "name": "ios-device-release",
            "displayName": "iOS Device Release",
            "inherits": "ios-device-debug",
            "binaryDir": "${sourceDir}/Build/ios-device-release"
        },
        {
            "name": "ios-simulator-debug",
            "displayName": "iOS Simulator Debug",
            "inherits": "ios-device-debug",
            "binaryDir": "${sourceDir}/Build/ios-simulator-debug",
            "cacheVariables": {
                "VE_IOS_SDK": "iphonesimulator",
                "VE_IOS_ARCHITECTURES": "arm64"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-msvc-debug",
            "configurePreset": "windows-msvc-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-msvc-release",
            "configurePreset": "windows-msvc-release",
            "configuration": "Release"
        },
        {
            "name": "windows-msvc-tests",
            "configurePreset": "windows-msvc-tests",
            "configuration": "Debug"
        },
        {
            "name": "mac-debug",
            "configurePreset": "mac-debug",
            "configuration": "Debug"
        },
        {
            "name": "mac-release",
            "configurePreset": "mac-release",
            "configuration": "Release"
        },
        {
            "name": "mac-test",
            "configurePreset": "mac-test",
            "configuration": "Debug"
        },
        {
            "name": "ios-device-debug",
            "configurePreset": "ios-device-debug",
            "configuration": "Debug"
        },
        {
            "name": "ios-device-release",
            "configurePreset": "ios-device-release",
            "configuration": "Release"
        },
        {
            "name": "ios-simulator-debug",
            "configurePreset": "ios-simulator-debug",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "windows-msvc-tests",
            "configurePreset": "windows-msvc-tests",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
