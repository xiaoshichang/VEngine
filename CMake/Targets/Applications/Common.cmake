function(ve_add_editor_packaging_definitions target_name)
    target_compile_definitions(${target_name}
        PRIVATE
            VE_PROJECT_SOURCE_DIR="${PROJECT_SOURCE_DIR}"
            VE_CMAKE_BINARY_DIR="${CMAKE_BINARY_DIR}"
            VE_CMAKE_BUILD_CONFIG="$<CONFIG>"
    )
endfunction()
